---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/mainlayout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { slug: project.id },

    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;

// New Astro content API uses render(project)
const { Content } = await render(project);
---

<MainLayout title={`${project.data.title} | Alex Hordal`} isHome={false}>
  <div class="page-grid">
    <!-- Left Column -->
    <aside class="page-title-column">
      <h1 class={project.data.titleClass}>{project.data.title}</h1>

      <p class="page-subtitle">
        {project.data.description}
      </p>

      <div class="page-section">
        <Image
          src={project.data.featuredImage}
          alt={`Hero image for ${project.data.title}`}
          format="webp"
        />

        <p>Download the full PDF |</p>
      </div>
    </aside>

    <!-- Right Column -->
    <section class="page-content-column">
      <div class="page-section">
        <h2>About the Project</h2>

        <div>
          <Content />
        </div>
      </div>
      <div class="page-section">
        <h2>Technology Stack</h2>
        <ul class="mono-list">
          {project.data.technologies.map((tech) => <li>{tech}</li>)}
        </ul>
      </div>
      <div class="page-section">
        <h2>Applied Skills</h2>
        <ul class="mono-list">
          {project.data.appliedSkills?.map((skill) => <li>{skill}</li>)}
        </ul>
      </div>
    </section>
    <!-- Additional Experience & Training -->
  </div>
</MainLayout>
