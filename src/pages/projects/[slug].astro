---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/mainlayout.astro";
import PageSection from "../../components/PageSection.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { slug: project.id },

    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;

// New Astro content API uses render(project)
const { Content } = await render(project);

const slug = project.id;

const featuredImage = await import(
  `../../content/projects/${slug}/featured.webp`
);
---

<MainLayout title={`${project.data.plainTitle} | Alex Hordal`} isHome={false}>
  <div class={`page-grid ${project.data.layoutClass || ""}`}>
    <!-- Left Column -->
    <aside class="page-title-column">
      <h1 class={project.data.titleClass} set:html={project.data.title} />

      <p class="page-description">
        {project.data.description}
      </p>

      <div class="page-section">
        <a href={featuredImage.default.src}>
          <Image
            src={featuredImage.default}
            alt={`Hero image for ${project.data.title}`}
            width={1000}
            format="webp"
          />
        </a>
        <p>{
  project.data.downloadFile && (
    <p>
      <a href={project.data.downloadFile}>
        {project.data.downloadLabel || "Download Project File"}
      </a>
    </p>
  )
}</p>
      </div>
    </aside>

    <!-- Right Column -->
    <section class="page-content-column">
      <PageSection title="About the Project">
       
        <div>
          <Content />
        </div>
      </PageSection>
      <PageSection title="Technology Stack">
        <ul class="mono-list">
          {project.data.technologies.map((tech) => <li>{tech}</li>)}
        </ul>
      </PageSection>
      <div class="page-section">
        <h2>Applied Skills</h2>
        <ul class="mono-list">
          {project.data.appliedSkills?.map((skill) => <li>{skill}</li>)}
        </ul>
      </div>
    </section>
    <!-- Additional Experience & Training -->
  </div>
</MainLayout>
