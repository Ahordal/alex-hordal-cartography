---
import { getCollection, render, type CollectionEntry } from "astro:content";
import MainLayout from "../../layouts/mainlayout.astro";
import PageSection from "../../components/PageSection.astro";
import ProjectHero from "../../components/ProjectHero.astro";
import ProjectResources from "../../components/ProjectResources.astro";

import Link from "../../components/Link.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;

// Render MDX content
const { Content } = await render(project);
---

<MainLayout
  id="top"
  title={`${project.data.plainTitle} | Alex Hordal`}
  description={project.data.description}
  isHome={false}
>

  <div class="page-grid">

    <!-- Left Column -->
    <aside class="page-title-column">

      <nav class="project-path">

        <span>/ </span>

        <a href="/portfolio">
          portfolio
        </a>

        <span>/</span>

        <span class="project-slug">
          {project.id}
        </span>

      </nav>

      <h1 set:html={project.data.title} />

      <p class="page-description">
        {project.data.description}
      </p>

      <div class="page-section">

        <ProjectHero project={project} />

        {
          project.data.downloadFile && (
            <p>

              <a href={project.data.downloadFile}>
                {
                  project.data.downloadLabel ||
                  "Download Project File"
                }
              </a>

            </p>
          )
        }

      </div>

    </aside>

    <!-- Right Column -->
    <section class="page-content-column">

      {
        project.data.resources?.length && (
          <PageSection
            title={`<i class="fa-solid fa-folder-tree section-icon"></i> Project Files & Links`}
            id="resources"
          >

            <ProjectResources
              resources={project.data.resources}
            />

          </PageSection>
        )
      }

      <PageSection
        title={`<i class="fa-solid fa-circle-info section-icon"></i> About the Project`}
        id="about"
      >

        <div>

          <Content components={{ Link }} />

        </div>

      </PageSection>

      {
        project.data.technologies?.length && (
          <PageSection
            title={`<i class="fa-solid fa-microchip section-icon"></i> Technology Stack`}
            id="stack"
          >

            <ul class={`list ${project.data.listClass || ""}`}>

              {project.data.technologies.map((tech) => (
                <li>{tech}</li>
              ))}

            </ul>

          </PageSection>
        )
      }

      {
        project.data.appliedSkills?.length && (
          <PageSection
            title={`<i class="fa-solid fa-screwdriver section-icon"></i> Applied Skills`}
            id="applied-skills"
          >

            <ul class="list-justified">

              {project.data.appliedSkills.map((skill) => (
                <li>{skill}</li>
              ))}

            </ul>

          </PageSection>
        )
      }

      <a
        href="#top"
        class="back-to-top"
      >
        ↑ Back to top
      </a>

    </section>

    <!-- Additional Experience & Training -->
  </div>

</MainLayout>