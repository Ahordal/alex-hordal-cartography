---
import MainLayout from "../layouts/mainlayout.astro";
import PageSection from "../components/PageSection.astro";
import ProjectFigure from "../components/ProjectFigure.astro";
import ProjectResources from "../components/ProjectResources.astro";

import { Image } from "astro:assets";

import bioPic from "../assets/images/about/biopic.webp";

const resources = [
  {
    label: "Download My Resume",
    url: "https://assets.alexhordal.ca/Alex_Hordal_Resume_Online.pdf",
    icon: "fa-solid fa-file-pdf",
    description: "Professional resume and experience overview",
  },
  {
    label: "Explore My Story Map",
    url: "https://arcg.is/0zL0ie",
    icon: "fa-solid fa-book-open",
    description:
      "Background, field experience, and transition into GIS and cartography",
  },
];
---

<MainLayout id="top" title="About | Alex Hordal" isHome={false}>
  <div class="page-grid">
    <!-- Left Column -->
    <aside class="page-title-column">
      <nav class="project-path">
        <span>/ </span>

        <a href="/"> home </a>

        <span>/</span>

        <span class="project-slug"> about </span>
      </nav>

      <h1>About</h1>

      <p class="page-description">
        Bringing over a decade of experience in emergency response and mountain
        operations to cartography and GIS.
      </p>

      <div class="page-section">
        <h2>Background</h2>

        <ProjectFigure
          src={bioPic}
          alt="Alex and Ukee"
          caption="Alex and Ukee in Nova Scotia"
        />

        <p>
          My interest in GIS and cartography grew out of years working as a
          first responder in complex operational environments where spatial
          awareness and accurate geographic information can have real
          consequences. Through my experience as an Infantry Officer in the
          Canadian Armed Forces, as a Professional Ski Patroller at Whistler
          Blackcomb, and as a Paid-On-Call Firefighter with the Whistler Fire
          Rescue Service, I developed a strong appreciation for terrain,
          navigation, and the importance of reliable geographic information.
          These roles required teamwork, attention to detail, clear
          communication, and rapid decision-making in dynamic environments where
          terrain, navigation, and situational awareness were critical.
        </p>

        <p>
          During this time, I also began developing
          <a
            href="https://www.ullrmaps.com"
            target="_blank"
            rel="noopener noreferrer">ULLR Maps</a
          >, a terrain-focused mapping project originally created as a personal
          reference tool to better understand the complexity of Whistler
          Blackcomb's terrain. The project eventually grew into a public mapping
          platform and played an important role in my decision to pursue
          cartography and geographic information systems professionally.
        </p>

        <p>
          As I enter the geospatial field, I look forward to applying my
          experience in operational environments to developing maps and
          geospatial tools that help people better understand complex terrain
          and make informed decisions in real-world situations.
        </p>

        <ProjectResources resources={resources} />
      </div>
    </aside>

    <!-- Right Column -->
    <section class="page-content-column">
      <PageSection
        title={`<i class="fa-solid fa-graduation-cap section-icon"></i> Education`}
        id="education">
        <ul class="list">
          <li>
            <span class="bold">
              Diploma, GIS — Cartography &amp; Geovisualization<br />
            </span>
            Centre of Geographic Sciences (COGS), NSCC — 2026
          </li>

          <li>
            <span class="bold"> BA, Geography </span> — Queen's University — 2003
          </li>
        </ul>
      </PageSection>

      <PageSection
        title={`<i class="fa-solid fa-microchip section-icon"></i> Technical Profile`}
        id="technical-profile">
        <div class="page-subsection">
          <h3>GIS Platforms</h3>

          <ul class="list">
            <li>ArcGIS Pro</li>
            <li>ArcGIS Online</li>
            <li>ArcGIS Field Maps</li>
            <li>QGIS</li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Web Mapping & Development</h3>

          <ul class="list">
            <li>ArcGIS Maps SDK for JavaScript (foundational)</li>
            <li>ArcGIS StoryMaps</li>
            <li>Mapbox GL JS (foundational)</li>
            <li>HTML</li>
            <li>CSS</li>
            <li>JavaScript (foundational)</li>
            <li>Mapbox Studio</li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Programming & GIS Automation</h3>

          <ul class="list">
            <li>Python (foundational)</li>
            <li>ArcGIS Pro ModelBuilder (foundational)</li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Databases & Data Management</h3>

          <ul class="list">
            <li>PostgreSQL (foundational)</li>
            <li>pgAdmin (foundational)</li>
            <li>Relational database design (foundational)</li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Cartography & Geovisualization</h3>

          <ul class="list">
            <li>
              Terrain visualization including DEM and topo-bathymetric elevation
              processing, shaded relief design, and elevation modelling.
            </li>

            <li>Thematic cartography and spatial data representation</li>

            <li>Cartographic hierarchy, typography, and layout composition</li>

            <li>Colour theory and multivariate symbology design</li>

            <li>Narrative cartography and data-driven map design</li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Design & Visualization Tools</h3>

          <ul class="list">
            <li>Adobe Illustrator</li>
            <li>Adobe Photoshop</li>
            <li>Adobe InDesign</li>
            <li>Avenza MAPublisher</li>
            <li>Blender (foundational)</li>
          </ul>
        </div>
      </PageSection>

      <PageSection
        title={`<i class="fa-solid fa-id-card section-icon"></i> Professional Credentials`}
        id="credentials">
        <div class="page-subsection">
          <h3>Emergency Response & Operations</h3>

          <ul class="list">
            <li>
              <span class="bold"> Fire Fighter I & II (NFPA 1001) </span>
              — Justice Institute of British Columbia
            </li>

            <li>
              <span class="bold">
                Full Service Fire Fighter Operations Program
              </span>
              — Justice Institute of British Columbia
            </li>

            <li>
              <span class="bold"> Volunteer Recruit Training </span>
              — Halifax Regional Fire & Emergency
            </li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Avalanche & Mountain Operations</h3>

          <ul class="list">
            <li>
              <span class="bold"> Avalanche Operations Level 1 </span>
              — Canadian Avalanche Association
            </li>

            <li>
              <span class="bold"> Avalanche Skills Training Level 1 </span>
              — Avalanche Canada
            </li>

            <li>
              <span class="bold"> Introduction to Weather </span>
              — Canadian Avalanche Association
            </li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Military Training & Service</h3>

          <ul class="list">
            <li>
              <span class="bold"> Basic Military Qualification </span>
              — Canadian Armed Forces
            </li>

            <li>
              <span class="bold"> Basic Military Officer Qualification </span>
              — Canadian Armed Forces
            </li>
          </ul>
        </div>

        <div class="page-subsection">
          <h3>Additional Experience & Training</h3>

          <ul class="list">
            <li>
              <span class="bold"
                >Restricted Operator Certificate — Aeronautical (ROC-A)</span
              >
              — Transport Canada
            </li>
            <li>
              <span class="bold"> Class 3 License </span>
              — Valley Driving School
            </li>

            <li>
              <span class="bold"> IRATA Level 1 </span>
              — Pacific Ropes (former)
            </li>

            <li>
              <span class="bold"> OFA3 </span>
              — St. John Ambulance (former)
            </li>
          </ul>
        </div>
      </PageSection>

      <a href="#top" class="back-to-top"> ↑ Back to top </a>
    </section>
  </div>
</MainLayout>
