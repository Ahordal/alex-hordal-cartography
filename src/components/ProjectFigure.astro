---
import { Image } from "astro:assets";

interface Props {
  src?: any;
  alt?: string;
  caption?: string;
  class?: string;
  width?: number;
}

const {
  src,
  alt,
  caption,
  class: className,
  width,
} = Astro.props;
---

<figure class={`project-figure ${className || ""}`}>

  {
    src && typeof src === "object" ? (

      <a href={src.src}>

        <Image
          src={src}
          alt={alt || ""}
          width={width}
          format="webp"
        />

      </a>

    ) : (

      <slot />

    )
  }

  {caption && (
    <figcaption>
      <Fragment set:html={caption} />
    </figcaption>
  )}

</figure>