---
import "../styles/global.css";
const {
  title = "Alex Hordal | Cartographer & GIS Specialist",
  isHome = false,
} = Astro.props;
const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || pathname === path + "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <script
      src="https://kit.fontawesome.com/8b0dc5e073.js"
      crossorigin="anonymous"></script>
    <title>{title}</title>
  </head>
  <body class="site-root">
    <header class="main-nav">
      <nav class="nav-container">
        <button class="menu-toggle" aria-label="Open Menu">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>

        <div class="nav-links">
          <!-- Apply the conditional class 'active' -->
          <a href="/" class={isActive("/") ? "active" : ""}>Home</a>
          <a href="/about" class={isActive("/about") ? "active" : ""}>About</a>
          <a href="/portfolio" class={isActive("/portfolio") ? "active" : ""}
            >Portfolio</a
          >
          <a href="/contact" class={isActive("/contact") ? "active" : ""}
            >Contact</a
          >
        </div>
      </nav>
    </header>

    <main class={`page-slot ${isHome ? "home-bg" : "content-bg"}`}>
      <slot />
    </main>

    <footer class="main-footer">
      <div class="footer-container">
        <div class="footer-group">
          <span class="mono">LOC: DARTMOUTH, NS</span> <i class="fa-brands fa-canadian-maple-leaf"></i>
          <span class="mono separator">//</span>
          <span class="mono">44.66° N, 63.56° W</span>
        </div>

        <nav class="footer-group">
          <a
            href="https://www.ullrmaps.com"
            target="_blank"
            rel="noopener noreferrer">ULLR Maps</a
          >
          <span class="mono separator">|</span>
          <a href="/colophon" class={isActive("/colophon") ? "active" : ""}
            >Colophon</a
          >
          <span class="mono separator">|</span>
          <div class="social-links">
            <a
              href="https://linkedin.com/in/yourprofile"
              target="_blank"
              rel="noopener noreferrer"><i class="fa-brands fa-linkedin"></i></a
            >
            <a
              href="https://github.com/Ahordal"
              target="_blank"
              rel="noopener noreferrer"><i class="fa-brands fa-github"></i></a
            >
            <a
              href="https://instagram.com/yourhandle"
              target="_blank"
              rel="noopener noreferrer"><i class="fa-brands fa-instagram"></i></i></a
            >
          </div>
          <span class="mono separator">|</span>
          <span class="mono">© ALEX HORDAL 2026</span>
        </nav>
      </div>
    </footer>

    <script>
      // Simple toggle logic
      const menuBtn = document.querySelector(".menu-toggle");
      const navLinks = document.querySelector(".nav-links");

      menuBtn?.addEventListener("click", () => {
        navLinks?.classList.toggle("is-active");
      });
    </script>
  </body>
</html>
